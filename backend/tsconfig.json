{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "strict": false,                        // Вимикаємо загальний суворий режим
    "strictNullChecks": false,              // Дозволяємо null/undefined без постійних перевірок
    "noImplicitAny": false,                 // Дозволяємо не писати типи там, де ліньки
    "strictPropertyInitialization": false,  // Прибирає помилки в Entity (ті самі "has no initializer")
    "ignoreDeprecations": "5.0"
  }
}
